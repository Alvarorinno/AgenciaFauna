# Copiar a .env para desarrollo local (nunca commitear .env real)

# Neon/Vercel Postgres — tomar el valor desde Vercel > Storage > (tu DB) > .env.local,
# o desde el dashboard de Neon si se provisionó directo ahí.
DATABASE_URL=postgres://usuario:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=fauna_secret_2026

# Passwords de usuarios reales (opcional — overrides de los defaults hardcodeados
# en server/db.js). Recomendado setear en producción en vez de depender del default.
FRANCISCA_PASS=
ALVARO_PASS=
EZEQUIEL_PASS=

# Solo desarrollo local (CORS del server hacia el Vite dev server)
CORS_ORIGIN=http://localhost:5173
